# Server Configuration
PORT=3000

# Webhook Configuration
# Secret key provided by Suby.fi for webhook signature verification
WEBHOOK_SECRET=your_webhook_secret_here

# API Configuration
# API key for authenticating with Suby.fi API (format: sk_live_xxx or sk_test_xxx)
SUBY_API_KEY=your_api_key_here
SUBY_API_URL=https://api.suby.fi
